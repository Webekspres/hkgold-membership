      "Bash(mkdir -p modules/health/types)",
      "Bash(mkdir -p modules/health/services)",
      "Bash(mkdir -p modules/health/routes)",
      "Bash(mkdir -p modules/aggregators)",
      "Bash(bun test *)",
      "Bash(bun remove *)",
      "Bash(git add *)"
    ]
  }
}

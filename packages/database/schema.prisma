generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMINISTRATOR @map("ADMINISTRATOR")
  SUPER_ADMIN   @map("SUPER_ADMIN")
  MARKETING     @map("MARKETING")
  STORE_MANAGER @map("STORE_MANAGER")
  MEMBER        @map("MEMBER")
}

enum TierStatus {
  SILVER   @map("SILVER")
  GOLD     @map("GOLD")
  PLATINUM @map("PLATINUM")
  SAPPHIRE @map("SAPPHIRE")
}

enum BatchStatus {
  PENDING    @map("PENDING")
  PROCESSING @map("PROCESSING")
  COMPLETED  @map("COMPLETED")
  FAILED     @map("FAILED")
}

enum ApprovalStatus {
  PENDING  @map("PENDING")
  APPROVED @map("APPROVED")
  REJECTED @map("REJECTED")
}

enum ContentType {
  NEWS       @map("NEWS")
  EVENT      @map("EVENT")
  EXHIBITION @map("EXHIBITION")
  BANNER     @map("BANNER")
}

enum ContentStatus {
  DRAFT     @map("draft")
  ARCHIVED  @map("archived")
  PUBLISHED @map("published")
}

model PasswordResetToken {
  email     String    @id @db.VarChar(255)
  token     String    @db.VarChar(255)
  createdAt DateTime? @map("created_at")

  @@map("password_reset_tokens")
}

model Session {
  id           String  @id @db.VarChar(255)
  userId       String? @map("user_id") @db.Char(36)
  ipAddress    String? @map("ip_address") @db.VarChar(45)
  userAgent    String? @map("user_agent") @db.Text
  payload      String  @db.LongText
  lastActivity Int     @map("last_activity")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lastActivity])
  @@map("sessions")
}

model Cache {
  key        String @id @db.VarChar(255)
  value      String @db.MediumText
  expiration BigInt @db.BigInt

  @@index([expiration])
  @@map("cache")
}

model CacheLock {
  key        String @id @db.VarChar(255)
  owner      String @db.VarChar(255)
  expiration BigInt @db.BigInt

  @@index([expiration])
  @@map("cache_locks")
}

model QueueJob {
  id          BigInt @id @default(autoincrement())
  queue       String @db.VarChar(255)
  payload     String @db.LongText
  attempts    Int    @db.UnsignedSmallInt
  reservedAt  Int?   @map("reserved_at") @db.UnsignedInt
  availableAt Int    @map("available_at") @db.UnsignedInt
  createdAt   Int    @map("created_at") @db.UnsignedInt

  @@index([queue])
  @@map("jobs")
}

model JobBatch {
  id           String  @id @db.VarChar(255)
  name         String  @db.VarChar(255)
  totalJobs    Int     @map("total_jobs")
  pendingJobs  Int     @map("pending_jobs")
  failedJobs   Int     @map("failed_jobs")
  failedJobIds String  @map("failed_job_ids") @db.LongText
  options      String? @db.MediumText
  cancelledAt  Int?    @map("cancelled_at")
  createdAt    Int     @map("created_at")
  finishedAt   Int?    @map("finished_at")

  @@map("job_batches")
}

model FailedJob {
  id         BigInt   @id @default(autoincrement())
  uuid       String   @unique @db.VarChar(255)
  connection String   @db.VarChar(255)
  queue      String   @db.VarChar(255)
  payload    String   @db.LongText
  exception  String   @db.LongText
  failedAt   DateTime @default(now()) @map("failed_at")

  @@index([connection, queue, failedAt])
  @@map("failed_jobs")
}

model Permission {
  id        BigInt   @id @default(autoincrement())
  name      String   @db.VarChar(255)
  guardName String   @map("guard_name") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  modelHasPermissions ModelHasPermission[]
  roleHasPermissions  RoleHasPermission[]

  @@unique([name, guardName])
  @@map("permissions")
}

model SpatieRole {
  id        BigInt   @id @default(autoincrement())
  name      String   @db.VarChar(255)
  guardName String   @map("guard_name") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  modelHasRoles      ModelHasRole[]
  roleHasPermissions RoleHasPermission[]

  @@unique([name, guardName])
  @@map("roles")
}

model ModelHasPermission {
  permissionId BigInt @map("permission_id")
  modelType    String @map("model_type") @db.VarChar(255)
  modelUuid    String @map("model_uuid") @db.Char(36)

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user       User?      @relation(fields: [modelUuid], references: [id], onDelete: Cascade)

  @@id([permissionId, modelUuid, modelType])
  @@index([modelUuid, modelType], map: "model_has_permissions_model_id_model_type_index")
  @@map("model_has_permissions")
}

model ModelHasRole {
  roleId    BigInt @map("role_id")
  modelType String @map("model_type") @db.VarChar(255)
  modelUuid String @map("model_uuid") @db.Char(36)

  role SpatieRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user User?      @relation(fields: [modelUuid], references: [id], onDelete: Cascade)

  @@id([roleId, modelUuid, modelType])
  @@index([modelUuid, modelType], map: "model_has_roles_model_id_model_type_index")
  @@map("model_has_roles")
}

model RoleHasPermission {
  permissionId BigInt @map("permission_id")
  roleId       BigInt @map("role_id")

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role       SpatieRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([permissionId, roleId])
  @@map("role_has_permissions")
}

model Nation {
  id             Int      @id @default(autoincrement())
  nationCode     Int      @map("nation_code") @db.UnsignedInt
  iso2           String   @db.VarChar(2)
  iso3           String   @db.VarChar(3)
  nama           String   @db.VarChar(100)
  mataUang       String   @map("mata_uang") @db.VarChar(50)
  kodeMataUang   String   @map("kode_mata_uang") @db.VarChar(10)
  simbolMataUang String   @map("simbol_mata_uang") @db.VarChar(10)
  satuanBerat    String   @map("satuan_berat") @db.VarChar(10)
  satuanPanjang  String   @map("satuan_panjang") @db.VarChar(10)
  latitude       Decimal? @db.Decimal(15, 11)
  longitude      Decimal? @db.Decimal(15, 11)
  isProvinsi     Boolean  @default(false) @map("is_provinsi")
  isKabkota      Boolean  @default(false) @map("is_kabkota")
  isKecamatan    Boolean  @default(false) @map("is_kecamatan")
  isKelurahan    Boolean  @default(false) @map("is_kelurahan")
  isKodepos      Boolean  @default(false) @map("is_kodepos")
  isActive       Boolean  @default(true) @map("is_active")

  provinces Province[]

  @@map("nations")
}

model Province {
  id        Int      @id @default(autoincrement())
  nationId  Int      @map("nation_id")
  nama      String   @db.VarChar(150)
  latitude  Decimal? @db.Decimal(15, 11)
  longitude Decimal? @db.Decimal(15, 11)

  nation Nation @relation(fields: [nationId], references: [id], onDelete: Cascade)
  cities City[]

  @@index([nationId])
  @@map("provinces")
}

model City {
  id         Int      @id @default(autoincrement())
  provinceId Int      @map("province_id")
  nama       String   @db.VarChar(150)
  latitude   Decimal? @db.Decimal(15, 11)
  longitude  Decimal? @db.Decimal(15, 11)

  province      Province      @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  subDistricts  SubDistrict[]
  postalCodes   PostalCode[]

  @@index([provinceId])
  @@map("cities")
}

model SubDistrict {
  id        Int      @id @default(autoincrement())
  cityId    Int      @map("city_id")
  nama      String   @db.VarChar(150)
  latitude  Decimal? @db.Decimal(15, 11)
  longitude Decimal? @db.Decimal(15, 11)

  city        City         @relation(fields: [cityId], references: [id], onDelete: Cascade)
  villages    Village[]
  postalCodes PostalCode[]

  @@index([cityId])
  @@map("sub_districts")
}

model Village {
  id            Int      @id @default(autoincrement())
  subDistrictId Int      @map("sub_district_id")
  nama          String   @db.VarChar(150)
  latitude      Decimal? @db.Decimal(15, 11)
  longitude     Decimal? @db.Decimal(15, 11)

  subDistrict SubDistrict @relation(fields: [subDistrictId], references: [id], onDelete: Cascade)
  addresses   Address[]

  @@index([subDistrictId])
  @@map("villages")
}

model PostalCode {
  id            Int    @id @default(autoincrement())
  cityId        Int    @map("city_id")
  subDistrictId Int    @map("sub_district_id")
  kodepos       String @db.VarChar(20)

  city        City        @relation(fields: [cityId], references: [id], onDelete: Cascade)
  subDistrict SubDistrict @relation(fields: [subDistrictId], references: [id], onDelete: Cascade)
  addresses   Address[]

  @@index([cityId, subDistrictId])
  @@index([kodepos])
  @@map("postal_codes")
}

model Address {
  id           String @id @default(uuid()) @db.Char(36)
  villageId    Int    @map("village_id")
  postalCodeId Int    @map("postal_code_id")
  street       String @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  village    Village    @relation(fields: [villageId], references: [id])
  postalCode PostalCode @relation(fields: [postalCodeId], references: [id])
  members    Member[]
  branches   Branch[]

  @@index([villageId])
  @@index([postalCodeId])
  @@map("addresses")
}

model Media {
  id        String   @id @default(uuid()) @db.Char(36)
  caption   String?  @db.Text
  fileName  String   @map("file_name") @db.VarChar(255)
  fileType  String   @map("file_type") @db.VarChar(255)
  fileUrl   String   @map("file_url") @db.Text
  fileSize  Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profilePhotoUser   User?               @relation("UserProfilePhoto")
  rewardImages       RewardImage[]
  contentCoverImages ContentCoverImage[]
  promotionBanners   PromotionBanner[]

  @@map("media")
}

model Branch {
  id                Int      @id @default(autoincrement())
  branchCode        String   @unique @map("branch_code") @db.VarChar(10)
  name              String   @db.VarChar(100)
  address           String   @db.Text
  addressId         String?  @map("address_id") @db.Char(36)
  phone             String?  @db.VarChar(20)
  isOnlineWarehouse Boolean  @default(false) @map("is_online_warehouse")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  normalizedAddress  Address?            @relation(fields: [addressId], references: [id], onDelete: SetNull)
  staffs             Staff[]
  membersRegistered  Member[]            @relation("BranchRegistration")
  rewardBranchStocks RewardBranchStock[]
  redeemInvoices     RedeemInvoice[]
  redeemTokens       RedeemToken[]
  clockInLogs        StaffClockInLog[]
  pointMutations     PointMutation[]

  @@index([addressId])
  @@map("branches")
}

model User {
  id             String    @id @default(uuid()) @db.Char(36)
  email          String    @unique @db.VarChar(255)
  password       String    @db.VarChar(255)
  role           Role
  fullName       String    @map("full_name") @db.VarChar(150)
  profilePhotoId String?   @unique @map("profile_photo_id") @db.Char(36)
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  profilePhoto      Media?               @relation("UserProfilePhoto", fields: [profilePhotoId], references: [id], onDelete: SetNull)
  staff             Staff?
  member            Member?
  trustedDevices    TrustedDevice[]
  notifications     Notification[]
  sessions          Session[]
  modelHasRoles     ModelHasRole[]
  modelHasPermissions ModelHasPermission[]

  @@map("users")
}

model Staff {
  id           Int       @id @default(autoincrement())
  userId       String    @unique @map("user_id") @db.Char(36)
  branchId     Int       @map("branch_id")
  employeeCode String    @unique @map("employee_code") @db.VarChar(20)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  user                    User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch                  Branch                @relation(fields: [branchId], references: [id])
  clockInLogs             StaffClockInLog[]
  pointInjectionBatches   PointInjectionBatch[]
  processedRedeemInvoices RedeemInvoice[]
  changePhoneRequests     ChangePhoneApproval[] @relation("RequestChangePhone")
  changePhoneApprovals    ChangePhoneApproval[] @relation("ApproveChangePhone")
  activityLogs            ActivityLog[]

  @@index([branchId])
  @@map("staffs")
}

model Member {
  id                   String     @id @default(uuid()) @db.Char(36)
  userId               String     @unique @map("user_id") @db.Char(36)
  registeredAtBranchId Int?       @map("registered_at_branch_id")
  addressId            String?    @map("address_id") @db.Char(36)
  memberNumber         String     @unique @map("member_number") @db.VarChar(15)
  phoneNumber          String     @unique @map("phone_number") @db.VarChar(20)
  currentTier          TierStatus @default(SILVER) @map("current_tier")
  pointBalance         Int        @default(0) @map("point_balance")
  lastActivityAt       DateTime   @default(now()) @map("last_activity_at")
  isSuspended          Boolean    @default(false) @map("is_suspended")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  deletedAt            DateTime?  @map("deleted_at")

  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  registeredBranch     Branch?              @relation("BranchRegistration", fields: [registeredAtBranchId], references: [id], onDelete: SetNull)
  domicileAddress      Address?             @relation(fields: [addressId], references: [id], onDelete: SetNull)
  pointMutations       PointMutation[]
  pointAnnualArchives  PointAnnualArchive[]
  changePhoneApprovals ChangePhoneApproval[]
  redeemInvoices       RedeemInvoice[]
  redeemTokens         RedeemToken[]
  anomalies            MemberAnomaly[]

  @@index([registeredAtBranchId])
  @@index([addressId])
  @@map("members")
}

model TrustedDevice {
  id           String    @id @default(uuid()) @db.Char(36)
  userId       String    @map("user_id") @db.Char(36)
  deviceUuid   String    @unique @map("device_uuid") @db.VarChar(255)
  deviceName   String    @map("device_name") @db.VarChar(100)
  platform     String    @db.VarChar(255)
  isApproved   Boolean   @default(false) @map("is_approved")
  authorizedAt DateTime? @map("authorized_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("trusted_devices")
}

model ChangePhoneApproval {
  id             String         @id @default(uuid()) @db.Char(36)
  memberId       String?        @map("member_id") @db.Char(36)
  requestedById  Int            @map("requested_by_id")
  approvedById   Int?           @map("approved_by_id")
  oldPhoneNumber String         @map("old_phone_number") @db.VarChar(20)
  newPhoneNumber String         @unique @map("new_phone_number") @db.VarChar(20)
  status         ApprovalStatus @default(PENDING) @map("status")
  reason         String?        @db.Text
  actionNotes    String?        @map("action_notes") @db.Text
  processedAt    DateTime?      @map("processed_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  member      Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  requestedBy Staff   @relation("RequestChangePhone", fields: [requestedById], references: [id])
  approvedBy  Staff?  @relation("ApproveChangePhone", fields: [approvedById], references: [id])

  @@index([memberId])
  @@index([requestedById])
  @@index([approvedById])
  @@map("change_phone_approvals")
}

model StaffClockInLog {
  id        BigInt   @id @default(autoincrement())
  staffId   Int      @map("staff_id")
  branchId  Int      @map("branch_id")
  clockInAt DateTime @default(now()) @map("clock_in_at")
  loginIp   String   @map("login_ip") @db.VarChar(45)
  userAgent String   @map("user_agent") @db.Text

  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id])

  @@index([staffId])
  @@index([branchId])
  @@map("staff_clock_in_logs")
}

model OtpVerification {
  id         String   @id @default(uuid()) @db.Char(36)
  identifier String   @db.VarChar(100)
  otpCode    String   @map("otp_code") @db.VarChar(10)
  type       String   @db.VarChar(255)
  isUsed     Boolean  @default(false) @map("is_used")
  expiredAt  DateTime @map("expired_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier, otpCode])
  @@map("otp_verifications")
}

model Notification {
  id          String    @id @default(uuid()) @db.Char(36)
  userId      String?   @map("user_id") @db.Char(36)
  title       String    @db.VarChar(150)
  body        String    @db.Text
  platform    String    @db.VarChar(255)
  dataPayload Json?     @map("data_payload")
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

model CategoryReward {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rewards Reward[]

  @@map("category_rewards")
}

model Reward {
  id             String   @id @default(uuid()) @db.Char(36)
  categoryId     Int      @map("category_id")
  name           String   @db.VarChar(150)
  sku            String   @unique @db.VarChar(50)
  description    String   @db.Text
  pointsRequired Int      @map("points_required")
  isActive       Boolean  @default(true) @map("is_active")
  startAt        DateTime @map("start_at")
  endAt          DateTime @map("end_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  category           CategoryReward      @relation(fields: [categoryId], references: [id])
  rewardImages       RewardImage[]
  rewardBranchStocks RewardBranchStock[]
  redeemTokens       RedeemToken[]
  redeemInvoices     RedeemInvoice[]

  @@index([categoryId])
  @@map("rewards")
}

model RewardImage {
  id        String   @id @default(uuid()) @db.Char(36)
  rewardId  String   @map("reward_id") @db.Char(36)
  mediaId   String   @map("media_id") @db.Char(36)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  reward Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  media  Media  @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@unique([rewardId, mediaId])
  @@index([mediaId])
  @@map("reward_images")
}

model RewardBranchStock {
  id          String   @id @default(uuid()) @db.Char(36)
  rewardId    String   @map("reward_id") @db.Char(36)
  branchId    Int      @map("branch_id")
  actualStock Int      @default(0) @map("actual_stock")
  heldStock   Int      @default(0) @map("held_stock")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  reward Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@unique([rewardId, branchId])
  @@index([branchId])
  @@map("reward_branch_stocks")
}

model Content {
  id          String        @id @default(uuid()) @db.Char(36)
  type        ContentType
  title       String        @db.VarChar(200)
  slug        String        @unique @db.VarChar(200)
  bodyContent String        @map("body_content") @db.LongText
  eventDate   DateTime?     @map("event_date")
  status      ContentStatus @default(DRAFT) @map("status")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  contentCoverImages ContentCoverImage[]

  @@map("contents")
}

model ContentCoverImage {
  id        String   @id @default(uuid()) @db.Char(36)
  contentId String   @map("content_id") @db.Char(36)
  mediaId   String   @map("media_id") @db.Char(36)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@unique([contentId, mediaId])
  @@index([mediaId])
  @@map("content_cover_images")
}

model PromotionBanner {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String   @db.VarChar(150)
  mediaId   String   @map("media_id") @db.Char(36)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  media Media @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@index([mediaId])
  @@map("promotion_banners")
}

model TransactionType {
  id          Int      @id @default(autoincrement())
  typeKey     String   @unique @map("type_key") @db.VarChar(50)
  displayName String   @map("display_name") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  conversionRules       ConversionRule[]
  pointInjectionDetails PointInjectionDetail[]
  pointMutations        PointMutation[]

  @@map("transaction_types")
}

model TierMember {
  id        Int        @id @default(autoincrement())
  tierCode  TierStatus @unique @map("tier_code")
  minPoints Int        @map("min_points")
  maxPoints Int        @map("max_points")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  conversionRules ConversionRule[]

  @@map("tier_members")
}

model ConversionRule {
  id                String   @id @default(uuid()) @db.Char(36)
  transactionTypeId Int      @map("transaction_type_id")
  tierMemberId      Int      @map("tier_member_id")
  conversionNominal Decimal  @map("conversion_nominal") @db.Decimal(15, 2)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  transactionType TransactionType @relation(fields: [transactionTypeId], references: [id], onDelete: Cascade)
  tierMember      TierMember      @relation(fields: [tierMemberId], references: [id], onDelete: Cascade)

  @@unique([transactionTypeId, tierMemberId])
  @@index([tierMemberId])
  @@map("conversion_rules")
}

model PointInjectionBatch {
  id                  String   @id @default(uuid()) @db.Char(36)
  staffId             Int      @map("staff_id")
  fileName            String   @map("file_name") @db.VarChar(255)
  totalRows           Int      @default(0) @map("total_rows")
  successfulRows      Int      @default(0) @map("successful_rows")
  failedRows          Int      @default(0) @map("failed_rows")
  totalPointsInjected Int      @default(0) @map("total_points_injected")
  uploadedAt          DateTime @default(now()) @map("uploaded_at")

  staff   Staff                  @relation(fields: [staffId], references: [id])
  details PointInjectionDetail[]

  @@index([staffId])
  @@map("point_injection_batches")
}

model PointInjectionDetail {
  id                BigInt      @id @default(autoincrement())
  batchId           String      @map("batch_id") @db.Char(36)
  rowNumber         Int         @map("row_number")
  rawMemberNumber   String      @map("raw_member_number") @db.VarChar(50)
  rawBranchCode     String      @map("raw_branch_code") @db.VarChar(20)
  purchaseNominal   Decimal     @map("purchase_nominal") @db.Decimal(15, 2)
  transactionTypeId Int         @map("transaction_type_id")
  transactionDate   DateTime    @map("transaction_date")
  calculatedPoints  Int         @default(0) @map("calculated_points")
  status            BatchStatus @default(PENDING) @map("status")
  errorMessage      String?     @map("error_message") @db.Text
  processedAt       DateTime?   @map("processed_at")

  batch           PointInjectionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  transactionType TransactionType     @relation(fields: [transactionTypeId], references: [id])

  @@index([batchId])
  @@index([transactionTypeId])
  @@map("point_injection_details")
}

model PointMutation {
  id                String   @id @default(uuid()) @db.Char(36)
  memberId          String?  @map("member_id") @db.Char(36)
  branchId          Int      @map("branch_id")
  referenceId       String?  @map("reference_id") @db.VarChar(100)
  transactionTypeId Int?     @map("transaction_type_id")
  purchaseNominal   Decimal  @default(0) @map("purchase_nominal") @db.Decimal(15, 2)
  pointsIssued      Int      @default(0) @map("points_issued")
  pointsRedeemed    Int      @default(0) @map("points_redeemed")
  balanceSnapshot   Int      @map("balance_snapshot")
  transactionDate   DateTime @map("transaction_date")
  uploadedAt        DateTime @default(now()) @map("uploaded_at")

  member          Member?          @relation(fields: [memberId], references: [id], onDelete: SetNull)
  branch          Branch           @relation(fields: [branchId], references: [id])
  transactionType TransactionType? @relation(fields: [transactionTypeId], references: [id], onDelete: Restrict)

  @@index([memberId])
  @@index([branchId])
  @@index([transactionTypeId])
  @@map("point_mutations")
}

model PointAnnualArchive {
  id                String     @id @default(uuid()) @db.Char(36)
  memberId          String?    @map("member_id") @db.Char(36)
  archiveYear       Int        @map("archive_year")
  frozenPointsTotal Int        @map("frozen_points_total")
  lastTierPosition  TierStatus @map("last_tier_position")
  frozenAt          DateTime   @default(now()) @map("frozen_at")

  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([memberId])
  @@map("point_annual_archives")
}

model RedeemToken {
  id         String   @id @default(uuid()) @db.Char(36)
  memberId   String   @map("member_id") @db.Char(36)
  rewardId   String   @map("reward_id") @db.Char(36)
  branchId   Int      @map("branch_id")
  tokenCode  String   @unique @map("token_code") @db.VarChar(10)
  heldPoints Int      @map("held_points")
  isUsed     Boolean  @default(false) @map("is_used")
  expiredAt  DateTime @map("expired_at")
  createdAt  DateTime @default(now()) @map("created_at")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  reward Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id])

  @@index([memberId])
  @@index([rewardId])
  @@index([branchId])
  @@index([tokenCode, isUsed, expiredAt])
  @@map("redeem_tokens")
}

model RedeemInvoice {
  id             String   @id @default(uuid()) @db.Char(36)
  invoiceNumber  String   @unique @map("invoice_number") @db.VarChar(50)
  memberId       String?  @map("member_id") @db.Char(36)
  staffId        Int      @map("staff_id")
  branchId       Int      @map("branch_id")
  rewardId       String   @map("reward_id") @db.Char(36)
  pointsRedeemed Int      @map("points_redeemed")
  status         String   @default("COMPLETED") @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  staff  Staff   @relation(fields: [staffId], references: [id])
  branch Branch  @relation(fields: [branchId], references: [id])
  reward Reward  @relation(fields: [rewardId], references: [id])

  @@index([memberId])
  @@index([staffId])
  @@index([branchId])
  @@index([rewardId])
  @@map("redeem_invoices")
}

model MemberAnomaly {
  id             String   @id @default(uuid()) @db.Char(36)
  memberId       String   @map("member_id") @db.Char(36)
  lastMutationAt DateTime @map("last_mutation_at")
  hoardedPoints  Int      @map("hoarded_points")
  detectedAt     DateTime @default(now()) @map("detected_at")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("member_anomalies")
}

model FraudSuspect {
  id                String   @id @default(uuid()) @db.Char(36)
  detectedName      String   @map("detected_name") @db.VarChar(150)
  detectedBirthDate DateTime @map("detected_birth_date")
  suspectMemberIds  Json     @map("suspect_member_ids")
  status            String   @default("PENDING_REVIEW") @db.VarChar(255)
  adminNotes        String?  @map("admin_notes") @db.Text
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("fraud_suspects")
}

model ActivityLog {
  id            String   @id @default(uuid()) @db.Char(36)
  staffId       Int?     @map("staff_id")
  action        String   @db.VarChar(100)
  description   String   @db.Text
  auditableType String   @map("auditable_type") @db.VarChar(100)
  auditableId   String   @map("auditable_id") @db.VarChar(50)
  beforeJson    Json?    @map("before_json")
  afterJson     Json?    @map("after_json")
  ipAddress     String   @map("ip_address") @db.VarChar(45)
  createdAt     DateTime @default(now()) @map("created_at")

  staff Staff? @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@index([staffId])
  @@index([auditableType, auditableId])
  @@map("activity_logs")
}

// schema.prisma
// Sistem Loyalitas Mala Emas (HK GOLD VIP) — Versi 2
// Stack: Laravel 13 Eloquent (Filament) & ElysiaJS + Prisma (Express Engine)

generator client {
  provider = "prisma-client-js"
  output   = "../../apps/api-elysia/node_modules/.prisma/client"
}

datasource db {
  provider = "mysql"
}

// =============================================================================
// ENUMS
// =============================================================================

enum Role {
  ADMINISTRATOR
  SUPERADMIN
  MARKETING
  STORE_MANAGER
  MEMBER
}

enum MemberTier {
  SILVER
  GOLD
  PLATINUM
  SAPPHIRE
}

enum InjectionStatus {
  PENDING
  VALIDATED
  FAILED
  SUCCESS
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB_BROWSER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum OtpType {
  STAFF_DEVICE_REGISTRATION // OTP untuk lock device 42 staf internal
  REDEEM_VALIDATION         // OTP WhatsApp saat Store Manager klik "Konfirmasi Tukarkan"
}

enum NotificationPlatform {
  WEB_BROWSER_PUSH // Web Push API (FCM/Vapid) untuk browser staf
  MOBILE_APP_PUSH  // Firebase Cloud Messaging (FCM) / APNS untuk React Native member
  WEB_ADMIN_IN_APP // Format khusus database-notifications milik Laravel Filament
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum CampaignStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ContentType {
  NEWS  // Artikel berita seputar emas & promo ritel
  EVENT // Jadwal kalender pameran emas luar kota
}

enum ContentStatus {
  DRAFT     @map("draft")
  ARCHIVED  @map("archived")
  PUBLISHED @map("published")
}

enum RedeemStatus {
  COMPLETED // Sukses diklaim dan diserahkan ke pelanggan
  REFUNDED  // Dibatalkan darurat oleh Store Manager (Poin balik, stok balik)
}

enum FraudStatus {
  PENDING_REVIEW // Ditampung untuk diperiksa manual oleh Administrator pusat
  CLEARED        // Dinyatakan bukan fraud setelah diperiksa
  SUSPENDED      // Resmi diblokir karena terbukti melakukan kloning identitas
}

// =============================================================================
// MASTER LOKASI (WILAYAH INDONESIA — sesuai alamat.sql)
// =============================================================================

model Nation {
  id              Int      @id @default(autoincrement())
  nationCode      Int      @map("nation_code") @db.UnsignedInt
  iso2            String   @db.VarChar(2)
  iso3            String   @db.VarChar(3)
  nama            String   @db.VarChar(100)
  mataUang        String   @map("mata_uang") @db.VarChar(50)
  kodeMataUang    String   @map("kode_mata_uang") @db.VarChar(10)
  simbolMataUang  String   @map("simbol_mata_uang") @db.VarChar(10)
  satuanBerat     String   @map("satuan_berat") @db.VarChar(10)
  satuanPanjang   String   @map("satuan_panjang") @db.VarChar(10)
  latitude        Decimal? @db.Decimal(15, 11)
  longitude       Decimal? @db.Decimal(15, 11)
  isProvinsi      Boolean  @default(false) @map("is_provinsi")
  isKabkota       Boolean  @default(false) @map("is_kabkota")
  isKecamatan     Boolean  @default(false) @map("is_kecamatan")
  isKelurahan     Boolean  @default(false) @map("is_kelurahan")
  isKodepos       Boolean  @default(false) @map("is_kodepos")
  isActive        Boolean  @default(true) @map("is_active")

  provinces Province[]

  @@map("nations")
}

model Province {
  id        Int      @id @default(autoincrement())
  nationId  Int      @map("nation_id")
  nama      String   @db.VarChar(150)
  latitude  Decimal? @db.Decimal(15, 11)
  longitude Decimal? @db.Decimal(15, 11)

  nation Nation @relation(fields: [nationId], references: [id], onDelete: Cascade)
  cities City[]

  @@index([nationId])
  @@map("provinces")
}

model City {
  id         Int      @id @default(autoincrement())
  provinceId Int      @map("province_id")
  nama       String   @db.VarChar(150)
  latitude   Decimal? @db.Decimal(15, 11)
  longitude  Decimal? @db.Decimal(15, 11)

  province     Province      @relation(fields: [provinceId], references: [id], onDelete: Cascade)
  subDistricts SubDistrict[]
  postalCodes  PostalCode[]

  @@index([provinceId])
  @@map("cities")
}

model SubDistrict {
  id        Int      @id @default(autoincrement())
  cityId    Int      @map("city_id")
  nama      String   @db.VarChar(150)
  latitude  Decimal? @db.Decimal(15, 11)
  longitude Decimal? @db.Decimal(15, 11)

  city        City         @relation(fields: [cityId], references: [id], onDelete: Cascade)
  villages    Village[]
  postalCodes PostalCode[]

  @@index([cityId])
  @@map("sub_districts")
}

model Village {
  id            Int      @id @default(autoincrement())
  subDistrictId Int      @map("sub_district_id")
  nama          String   @db.VarChar(150)
  latitude      Decimal? @db.Decimal(15, 11)
  longitude     Decimal? @db.Decimal(15, 11)

  subDistrict SubDistrict @relation(fields: [subDistrictId], references: [id], onDelete: Cascade)
  addresses   Address[]

  @@index([subDistrictId])
  @@map("villages")
}

model PostalCode {
  id            Int    @id @default(autoincrement())
  cityId        Int    @map("city_id")
  subDistrictId Int    @map("sub_district_id")
  kodepos       String @db.VarChar(20)

  city        City        @relation(fields: [cityId], references: [id], onDelete: Cascade)
  subDistrict SubDistrict @relation(fields: [subDistrictId], references: [id], onDelete: Cascade)
  addresses   Address[]

  @@index([cityId, subDistrictId])
  @@index([kodepos])
  @@map("postal_codes")
}

model Address {
  id           String @id @default(uuid()) @db.Char(36)
  villageId    Int    @map("village_id")
  postalCodeId Int    @map("postal_code_id")
  street       String @map("street") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  village    Village    @relation(fields: [villageId], references: [id])
  postalCode PostalCode @relation(fields: [postalCodeId], references: [id])
  members    Member[]
  branches   Branch[]

  @@index([villageId])
  @@index([postalCodeId])
  @@map("addresses")
}

// =============================================================================
// MEDIA (POLYMORPHIC VIA PIVOT — BUKAN FK LANGSUNG KE REWARD)
// =============================================================================

model Media {
  id        String   @id @default(uuid()) @db.Char(36)
  caption   String?  @map("caption") @db.Text
  fileName  String   @map("file_name") @db.VarChar(255)
  fileType  String   @map("file_type") @db.VarChar(255)
  fileUrl   String   @map("file_url") @db.Text
  fileSize  Int      @map("file_size") @db.Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profilePhotoUser    User?                 @relation("UserProfilePhoto")
  rewardImages        RewardImage[]
  contentCoverImages  ContentCoverImage[]
  promotionBanners    PromotionBanner[]
  pointInjectionBatch PointInjectionBatch?
  branchImages        BranchImage[]

  @@map("media")
}

// =============================================================================
// CABANG OPERASIONAL
// =============================================================================

model Branch {
  id                Int      @id @default(autoincrement())
  branchCode        String   @unique @map("branch_code") @db.VarChar(10) // e.g., 'HK01', 'HKONLINE'
  name              String   @map("name") @db.VarChar(100)
  address           String   @map("address") @db.Text // Alamat teks bebas untuk tampilan
  addressId         String?  @map("address_id") @db.Char(36) // Relasi ke master alamat ternormalisasi
  phone             String?  @map("phone") @db.VarChar(20)
  locationUrl       String?  @map("location_url") @db.VarChar(500) // Link Google Maps lokasi cabang
  isOnlineWarehouse Boolean  @default(false) @map("is_online_warehouse")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  normalizedAddress  Address?             @relation(fields: [addressId], references: [id], onDelete: SetNull)
  staffs             Staff[]
  membersRegistered  Member[]             @relation("BranchRegistration")
  rewardBranchStocks RewardBranchStock[]
  redeemInvoices     RedeemInvoice[]
  redeemTokens       RedeemToken[]
  clockInLogs        StaffClockInLog[]
  pointMutations     PointMutation[]
  images             BranchImage[]

  @@index([addressId])
  @@map("branches")
}

model BranchImage {
  id        String   @id @default(uuid()) @db.Char(36)
  branchId  Int      @map("branch_id")
  mediaId   String   @map("media_id") @db.Char(36)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  media  Media  @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@unique([branchId, mediaId])
  @@index([mediaId])
  @@map("branch_images")
}

// =============================================================================
// AUTENTIKASI & PROFIL PENGGUNA
// =============================================================================

model User {
  id             String    @id @default(uuid()) @db.Char(36)
  email          String    @unique @map("email") @db.VarChar(255)
  password       String    @map("password") @db.VarChar(255)
  role           Role      @map("role")
  fullName       String    @map("full_name") @db.VarChar(150)
  profilePhotoId String?   @unique @map("profile_photo_id") @db.Char(36)
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  profilePhoto   Media?          @relation("UserProfilePhoto", fields: [profilePhotoId], references: [id], onDelete: SetNull)
  staff          Staff?
  member         Member?
  trustedDevices TrustedDevice[]
  notifications  Notification[]
  notificationCampaigns NotificationCampaign[]
  activityLogs   ActivityLog[]

  @@map("users")
}

model Staff {
  id           Int       @id @default(autoincrement())
  userId       String    @unique @map("user_id") @db.Char(36)
  branchId     Int       @map("branch_id")
  employeeCode String    @unique @map("employee_code") @db.VarChar(20)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch                Branch                @relation(fields: [branchId], references: [id])
  clockInLogs           StaffClockInLog[]
  pointInjectionBatches PointInjectionBatch[]
  processedRedeemInvoices RedeemInvoice[]
  changePhoneRequests   ChangePhoneApproval[] @relation("RequestChangePhone")
  changePhoneApprovals  ChangePhoneApproval[] @relation("ApproveChangePhone")

  @@index([branchId])
  @@map("staffs")
}

model Member {
  id                   String     @id @default(uuid()) @db.Char(36)
  userId               String     @unique @map("user_id") @db.Char(36)
  registeredAtBranchId Int?       @map("registered_at_branch_id")
  addressId            String?    @map("address_id") @db.Char(36)
  memberNumber         String     @unique @map("member_number") @db.VarChar(15)
  phoneNumber          String     @unique @map("phone_number") @db.VarChar(20)
  currentTier          MemberTier @default(SILVER) @map("current_tier")
  pointBalance         Int        @default(0) @map("point_balance") // Single Wallet Terpusat
  highestPoint         Int        @default(0) @map("highest_point")
  lastActivityAt       DateTime   @default(now()) @map("last_activity_at")
  isSuspended          Boolean    @default(false) @map("is_suspended")
  birthDate            DateTime?  @map("birth_date")
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  deletedAt            DateTime?  @map("deleted_at")

  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  registeredBranch   Branch?              @relation("BranchRegistration", fields: [registeredAtBranchId], references: [id], onDelete: SetNull)
  domicileAddress    Address?             @relation(fields: [addressId], references: [id], onDelete: SetNull)
  pointMutations     PointMutation[]
  pointAnnualArchives PointAnnualArchive[]
  changePhoneApprovals ChangePhoneApproval[]
  redeemInvoices     RedeemInvoice[]
  redeemTokens       RedeemToken[]
  anomalies          MemberAnomaly[]

  @@index([registeredAtBranchId])
  @@index([addressId])
  @@map("members")
}

model TrustedDevice {
  id           String         @id @default(uuid()) @db.Char(36)
  userId       String         @map("user_id") @db.Char(36)
  deviceUuid   String         @unique @map("device_uuid") @db.VarChar(255)
  deviceName   String         @map("device_name") @db.VarChar(100)
  platform     DevicePlatform @map("platform")
  isApproved   Boolean        @default(false) @map("is_approved")
  authorizedAt DateTime?      @map("authorized_at")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("trusted_devices")
}

model ChangePhoneApproval {
  id             String         @id @default(uuid()) @db.Char(36)
  memberId       String?        @map("member_id") @db.Char(36)
  requestedById  Int            @map("requested_by_id")
  approvedById   Int?           @map("approved_by_id")
  oldPhoneNumber String         @map("old_phone_number") @db.VarChar(20)
  newPhoneNumber String         @unique @map("new_phone_number") @db.VarChar(20)
  status         ApprovalStatus @default(PENDING) @map("status")
  reason         String?        @map("reason") @db.Text
  actionNotes    String?        @map("action_notes") @db.Text
  processedAt    DateTime?      @map("processed_at")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  member      Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  requestedBy Staff   @relation("RequestChangePhone", fields: [requestedById], references: [id])
  approvedBy  Staff?  @relation("ApproveChangePhone", fields: [approvedById], references: [id])

  @@index([memberId])
  @@index([requestedById])
  @@index([approvedById])
  @@map("change_phone_approvals")
}

model StaffClockInLog {
  id        BigInt   @id @default(autoincrement())
  staffId   Int      @map("staff_id")
  branchId  Int      @map("branch_id")
  clockInAt DateTime @default(now()) @map("clock_in_at")
  loginIp   String   @map("login_ip") @db.VarChar(45)
  userAgent String   @map("user_agent") @db.Text

  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id])

  @@index([staffId])
  @@index([branchId])
  @@map("staff_clock_in_logs")
}

// =============================================================================
// NOTIFIKASI & OTP
// =============================================================================

model OtpVerification {
  id         String   @id @default(uuid()) @db.Char(36)
  identifier String   @map("identifier") @db.VarChar(100)
  otpCode    String   @map("otp_code") @db.VarChar(10)
  type       OtpType  @map("type")
  isUsed     Boolean  @default(false) @map("is_used")
  expiredAt  DateTime @map("expired_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier, otpCode])
  @@map("otp_verifications")
}

model Notification {
  id              String                     @id @default(uuid()) @db.Char(36)
  userId          String?                    @map("user_id") @db.Char(36)
  notificationKey String?                    @map("notification_key") @db.Char(36)
  title           String                     @map("title") @db.VarChar(150)
  body            String                     @map("body") @db.Text
  platform        NotificationPlatform       @map("platform")
  status          NotificationDeliveryStatus @default(PENDING) @map("status")
  dataPayload     Json?                      @map("data_payload")
  readAt          DateTime?                  @map("read_at")
  sentAt          DateTime?                  @map("sent_at")
  failedAt        DateTime?                  @map("failed_at")
  errorMessage    String?                    @map("error_message") @db.VarChar(500)
  attemptCount    Int                        @default(0) @map("attempt_count")
  createdAt       DateTime                   @default(now()) @map("created_at")
  updatedAt       DateTime                   @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, platform, createdAt])
  @@index([status, createdAt])
  @@unique([userId, notificationKey, platform])
  @@map("notifications")
}

model NotificationCampaign {
  id            String         @id @default(uuid()) @db.Char(36)
  title         String         @map("title") @db.VarChar(150)
  body          String         @map("body") @db.Text
  platforms     Json           @map("platforms")
  criteriaJson  Json?          @map("criteria_json")
  targetedCount Int            @default(0) @map("targeted_count")
  acceptedCount Int?           @map("accepted_count")
  failedCount   Int?           @map("failed_count")
  status        CampaignStatus @default(PENDING) @map("status")
  errorMessage  String?        @map("error_message") @db.VarChar(500)
  createdById   String?        @map("created_by_id") @db.Char(36)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@map("notification_campaigns")
}

// =============================================================================
// KATALOG HADIAH
// =============================================================================

model CategoryReward {
  id          Int      @id @default(autoincrement())
  name        String   @map("name") @db.VarChar(100)
  slug        String   @unique @map("slug") @db.VarChar(100)
  description String?  @map("description") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  rewards Reward[]

  @@map("category_rewards")
}

model Reward {
  id             String   @id @default(uuid()) @db.Char(36)
  categoryId     Int      @map("category_id")
  name           String   @map("name") @db.VarChar(150)
  sku            String   @unique @map("sku") @db.VarChar(50)
  description    String   @map("description") @db.Text
  pointsRequired Int      @map("points_required")
  isActive       Boolean  @default(true) @map("is_active")
  startAt        DateTime @map("start_at")
  endAt          DateTime @map("end_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  category           CategoryReward      @relation(fields: [categoryId], references: [id])
  rewardImages       RewardImage[]
  rewardBranchStocks RewardBranchStock[]
  redeemTokens       RedeemToken[]
  redeemInvoices     RedeemInvoice[]

  @@index([categoryId])
  @@map("rewards")
}

model RewardImage {
  id        String   @id @default(uuid()) @db.Char(36)
  rewardId  String   @map("reward_id") @db.Char(36)
  mediaId   String   @map("media_id") @db.Char(36)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  reward Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  media  Media  @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@unique([rewardId, mediaId])
  @@index([mediaId])
  @@map("reward_images")
}

model RewardBranchStock {
  id          String   @id @default(uuid()) @db.Char(36)
  rewardId    String   @map("reward_id") @db.Char(36)
  branchId    Int      @map("branch_id")
  actualStock Int      @default(0) @map("actual_stock")
  heldStock   Int      @default(0) @map("held_stock")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  reward Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Restrict)

  @@unique([rewardId, branchId])
  @@index([branchId])
  @@map("reward_branch_stocks")
}

// =============================================================================
// CMS KONTEN
// =============================================================================

model Content {
  id              String        @id @default(uuid()) @db.Char(36)
  type            ContentType   @map("type")
  title           String        @map("title") @db.VarChar(200)
  slug            String        @unique @map("slug") @db.VarChar(200)
  bodyContent     String        @map("body_content") @db.LongText
  eventDate       DateTime?     @map("event_date")
  locationAddress String?       @map("location_address") @db.Text
  locationUrl     String?       @map("location_url") @db.VarChar(500)
  status          ContentStatus @default(DRAFT) @map("status")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  contentCoverImages ContentCoverImage[]

  @@map("contents")
}

model ContentCoverImage {
  id        String   @id @default(uuid()) @db.Char(36)
  contentId String   @map("content_id") @db.Char(36)
  mediaId   String   @map("media_id") @db.Char(36)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  media   Media   @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@unique([contentId, mediaId])
  @@index([mediaId])
  @@map("content_cover_images")
}

model PromotionBanner {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String   @map("name") @db.VarChar(150)
  mediaId   String   @map("media_id") @db.Char(36)
  sortOrder Int      @default(0) @map("sort_order")
  linkUrl   String?  @map("link_url") @db.VarChar(500)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  media Media @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@index([mediaId])
  @@map("promotion_banners")
}

// =============================================================================
// KONFIGURASI DINAMIS (TIPE TRANSAKSI, TIER, KONVERSI)
// =============================================================================

model TransactionType {
  id          Int      @id @default(autoincrement())
  typeKey     String   @unique @map("type_key") @db.VarChar(50)
  displayName String   @map("display_name") @db.VarChar(100)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  conversionRules       ConversionRule[]
  pointInjectionDetails PointInjectionDetail[]
  pointMutations        PointMutation[]

  @@map("transaction_types")
}

model TierMember {
  id        Int        @id @default(autoincrement())
  tierCode  MemberTier @unique @map("tier_code")
  minPoints Int        @map("min_points")
  maxPoints Int        @map("max_points")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  conversionRules ConversionRule[]
  tierBenefits    TierBenefit[]

  @@map("tier_members")
}

model ConversionRule {
  id                String   @id @default(uuid()) @db.Char(36)
  transactionTypeId Int      @map("transaction_type_id")
  tierMemberId      Int      @map("tier_member_id")
  conversionNominal Decimal  @map("conversion_nominal") @db.Decimal(15, 2)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  transactionType TransactionType @relation(fields: [transactionTypeId], references: [id], onDelete: Cascade)
  tierMember      TierMember      @relation(fields: [tierMemberId], references: [id], onDelete: Cascade)

  @@unique([transactionTypeId, tierMemberId])
  @@index([tierMemberId])
  @@map("conversion_rules")
}

model TierBenefit {
  id           String   @id @default(uuid()) @db.Char(36)
  tierMemberId Int      @map("tier_member_id")
  title        String   @db.VarChar(255)
  description  String   @db.VarChar(255)
  sortOrder    Int      @default(0) @map("sort_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tierMember TierMember @relation(fields: [tierMemberId], references: [id], onDelete: Cascade)

  @@index([tierMemberId, sortOrder])
  @@map("tier_benefits")
}

// =============================================================================
// REKAYASA & STAGING POIN
// =============================================================================

model PointInjectionBatch {
  id                  String   @id @default(uuid()) @db.Char(36)
  staffId             Int?     @map("staff_id")
  mediaId             String   @unique @map("media_id") @db.Char(36)
  totalRows           Int      @default(0) @map("total_rows")
  successfulRows      Int      @default(0) @map("successful_rows")
  failedRows          Int      @default(0) @map("failed_rows")
  totalPointsInjected Int      @default(0) @map("total_points_injected")
  resolved            Boolean   @default(false) @map("resolved")
  uploadedAt          DateTime  @default(now()) @map("uploaded_at")
  importStartedAt     DateTime? @map("import_started_at")
  processingStartedAt DateTime? @map("processing_started_at")

  staff     Staff?                 @relation(fields: [staffId], references: [id], onDelete: SetNull)
  media     Media                  @relation(fields: [mediaId], references: [id], onDelete: Restrict)
  details   PointInjectionDetail[]
  mutations PointMutation[]

  @@index([staffId])
  @@map("point_injection_batches")
}

model PointInjectionDetail {
  id                BigInt          @id @default(autoincrement())
  batchId           String          @map("batch_id") @db.Char(36)
  rowNumber         Int             @map("row_number")
  rawMemberNumber   String          @map("raw_member_number") @db.VarChar(50)
  rawBranchCode     String          @map("raw_branch_code") @db.VarChar(20)
  purchaseNominal   Decimal         @map("purchase_nominal") @db.Decimal(15, 2)
  transactionTypeId Int?            @map("transaction_type_id")
  transactionDate   DateTime?       @map("transaction_date")
  calculatedPoints  Int             @default(0) @map("calculated_points")
  status            InjectionStatus @default(PENDING) @map("status")
  errorMessage      String?         @map("error_message") @db.Text
  processedAt       DateTime?       @map("processed_at")

  batch           PointInjectionBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  transactionType TransactionType?    @relation(fields: [transactionTypeId], references: [id], onDelete: Restrict)

  @@index([batchId])
  @@index([transactionTypeId])
  @@map("point_injection_details")
}

model PointMutation {
  id                String   @id @default(uuid()) @db.Char(36)
  memberId          String   @map("member_id") @db.Char(36)
  branchId          Int?     @map("branch_id")
  receiptNumber     String?  @map("receipt_number") @db.VarChar(100)
  sourceId          String?  @map("source_id") @db.Char(36)
  transactionTypeId Int?     @map("transaction_type_id")
  purchaseNominal   Decimal  @default(0.00) @map("purchase_nominal") @db.Decimal(15, 2)
  pointsIssued      Int      @default(0) @map("points_issued")
  pointsRedeemed    Int      @default(0) @map("points_redeemed")
  balanceSnapshot   Int      @map("balance_snapshot")
  transactionDate   DateTime @map("transaction_date")
  uploadedAt        DateTime @default(now()) @map("uploaded_at")

  member          Member               @relation(fields: [memberId], references: [id], onDelete: Restrict)
  branch          Branch?              @relation(fields: [branchId], references: [id], onDelete: SetNull)
  source          PointInjectionBatch? @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  transactionType TransactionType?     @relation(fields: [transactionTypeId], references: [id], onDelete: Restrict)

  @@index([memberId])
  @@index([branchId])
  @@index([sourceId])
  @@index([transactionTypeId])
  @@map("point_mutations")
}

model PointAnnualArchivePeriod {
  id                  String               @id @default(uuid()) @db.Char(36)
  archiveYear         Int                  @unique @map("archive_year")
  name                String               @map("name") @db.VarChar(150)
  totalMembers        Int                  @default(0) @map("total_members")
  frozenPointsTotal   Int                  @default(0) @map("frozen_points_total")
  earnedPointsTotal   Int                  @default(0) @map("earned_points_total")
  redeemedPointsTotal Int                  @default(0) @map("redeemed_points_total")
  archivedAt          DateTime?            @map("archived_at")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  archives PointAnnualArchive[]

  @@map("point_annual_archive_periods")
}

model PointAnnualArchive {
  id                String                   @id @default(uuid()) @db.Char(36)
  periodId          String                   @map("period_id") @db.Char(36)
  memberId          String?                  @map("member_id") @db.Char(36)
  frozenPointsTotal Int                      @map("frozen_points_total")
  highestPoint      Int                      @map("highest_point")
  lastTierPosition  MemberTier               @map("last_tier_position")
  frozenAt          DateTime                 @default(now()) @map("frozen_at")

  period PointAnnualArchivePeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  member Member?                  @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([periodId])
  @@index([memberId])
  @@map("point_annual_archives")
}

// =============================================================================
// REDEEM ENGINE (TRANSITIONAL & INVOICING)
// =============================================================================

model RedeemToken {
  id         String    @id @default(uuid()) @db.Char(36)
  memberId   String    @map("member_id") @db.Char(36)
  rewardId   String    @map("reward_id") @db.Char(36)
  branchId   Int       @map("branch_id")
  tokenCode  String    @unique @map("token_code") @db.VarChar(10)
  heldPoints Int       @map("held_points")
  isUsed     Boolean   @default(false) @map("is_used")
  expiredAt  DateTime  @map("expired_at")
  releasedAt DateTime? @map("released_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  reward Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id])

  @@index([memberId])
  @@index([rewardId])
  @@index([branchId])
  @@index([tokenCode, isUsed, expiredAt])
  @@map("redeem_tokens")
}

model RedeemInvoice {
  id             String       @id @default(uuid()) @db.Char(36)
  invoiceNumber  String       @unique @map("invoice_number") @db.VarChar(50)
  memberId       String?      @map("member_id") @db.Char(36)
  staffId        Int          @map("staff_id")
  branchId       Int          @map("branch_id")
  rewardId       String       @map("reward_id") @db.Char(36)
  pointsRedeemed Int          @map("points_redeemed")
  status         RedeemStatus @default(COMPLETED) @map("status")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  staff  Staff   @relation(fields: [staffId], references: [id])
  branch Branch  @relation(fields: [branchId], references: [id])
  reward Reward  @relation(fields: [rewardId], references: [id])

  @@index([memberId])
  @@index([staffId])
  @@index([branchId])
  @@index([rewardId])
  @@map("redeem_invoices")
}

// =============================================================================
// ANTI-FRAUD ENGINE & AUDIT LOG
// =============================================================================

model MemberAnomaly {
  id             String   @id @default(uuid()) @db.Char(36)
  memberId       String   @map("member_id") @db.Char(36)
  lastMutationAt DateTime @map("last_mutation_at")
  hoardedPoints  Int      @map("hoarded_points")
  detectedAt     DateTime @default(now()) @map("detected_at")

  member Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@map("member_anomalies")
}

model FraudSuspect {
  id                String      @id @default(uuid()) @db.Char(36)
  detectedName      String      @map("detected_name") @db.VarChar(150)
  detectedBirthDate DateTime    @map("detected_birth_date")
  suspectMemberIds  Json        @map("suspect_member_ids")
  status            FraudStatus @default(PENDING_REVIEW) @map("status")
  adminNotes        String?     @map("admin_notes") @db.Text
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  @@map("fraud_suspects")
}

model ActivityLog {
  id            String   @id @default(uuid()) @db.Char(36)
  userId        String?  @map("user_id") @db.Char(36)
  action        String   @map("action") @db.VarChar(100)
  description   String   @map("description") @db.Text
  auditableType String   @map("auditable_type") @db.VarChar(100)
  auditableId   String   @map("auditable_id") @db.VarChar(50)
  beforeJson    Json?    @map("before_json")
  afterJson     Json?    @map("after_json")
  ipAddress     String   @map("ip_address") @db.VarChar(45)
  createdAt     DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([auditableType, auditableId])
  @@map("activity_logs")
}

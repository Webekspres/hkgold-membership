# Copy keys ke Doppler project `hkgoldvip` / config `dev_backend`.
# Jangan commit secret. Jalankan app: bun run dev  (via `doppler run`)

# Database
DATABASE_URL="mysql://USER:PASSWORD@HOST:33068/hkgold_membership"

# API
BASE_URL=http://192.168.0.193:3000

# JWT
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=30d

# Object storage (MinIO lokal / Cloudflare R2)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_TOKEN=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=mala-emasda-media
CLOUDFLARE_R2_REGION=us-east-1
CLOUDFLARE_R2_ENDPOINT=http://192.168.0.193:9002
CLOUDFLARE_R2_PUBLIC_URL=http://192.168.0.193:9002/mala-emas-media

# Redis (OTP cache hybrid — DB 2 agar tidak bentrok queue Laravel di DB 0)
REDIS_URL=redis://192.168.0.109:6381/2
REDIS_HOST=192.168.0.109
REDIS_PORT=6381
REDIS_PASSWORD=
REDIS_DB=2

# Fonnte WhatsApp OTP
FONNTE_TOKEN=
FONNTE_BASE_URL=https://api.fonnte.com
FONNTE_OTP_MESSAGE_TEMPLATE=Kode OTP HK GOLD VIP Anda: {otp}. Berlaku 5 menit. Jangan bagikan kepada siapapun.

# Redeem timing (menit). Token default 30 = setengah jam
REDEEM_TOKEN_EXPIRY_MINUTES=30
REDEEM_OTP_EXPIRY_MINUTES=5

# Service-to-service auth (backoffice Filament → api-elysia)
MOBILE_API_INTERNAL_SECRET=

# =============================================================================
# HK Gold VIP Backoffice — contoh environment lokal (FlyEnv / artisan serve)
# Salin ke .env: cp .env.example .env && php artisan key:generate
# Infra Docker: docker compose up -d db redis minio minio-init
# =============================================================================

APP_NAME="HK Gold VIP Backoffice"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8800

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=33068
DB_DATABASE=hkgold_backoffice_filament
DB_USERNAME=root
DB_PASSWORD=root_password_super_secure

FILESYSTEM_DISK=local

# Queue — Redis dari docker-compose (host port 6381)
QUEUE_CONNECTION=redis
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6381
REDIS_PASSWORD=null

# MinIO sebagai R2 lokal (docker-compose port 9002)
CLOUDFLARE_R2_ACCOUNT_ID=local-minio
CLOUDFLARE_R2_ACCESS_KEY_ID=hkgold_minio
CLOUDFLARE_R2_SECRET_ACCESS_KEY=hkgold_minio_secret
CLOUDFLARE_R2_BUCKET=mala-emas-media
CLOUDFLARE_R2_REGION=us-east-1
CLOUDFLARE_R2_ENDPOINT=http://127.0.0.1:9002
CLOUDFLARE_R2_PUBLIC_URL=http://127.0.0.1:9002/mala-emas-media
R2_WIPE_ON_FRESH_SEED=true

SESSION_DRIVER=database
CACHE_STORE=database

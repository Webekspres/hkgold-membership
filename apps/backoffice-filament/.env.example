# Firebase Admin SDK (server → FCM)
FIREBASE_CREDENTIALS="D:/Project/hkgold-membership/apps/backoffice-filament/storage/app/firebase/service-account.json"

# Firebase Web client (browser → FCM token registration)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Web Push certificates (Firebase Console → Cloud Messaging → Web Push certificates)
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=
WEBPUSH_VAPID_SUBJECT=mailto:admin@hkgold.com

# Notifications queue
NOTIFICATIONS_QUEUE=notifications

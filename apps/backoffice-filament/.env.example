# =============================================================================
# HK Gold VIP Backoffice — env template
# Sumber kebenaran: Doppler project `hkgoldvip` / config `dev_backoffice`
# Jalankan: composer dev  (via `doppler run`)
# Jangan commit secret / APP_KEY nyata.
# =============================================================================

APP_NAME="HK Gold VIP Backoffice"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8800

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=192.168.0.193
DB_PORT=33068
DB_DATABASE=hkgold_backoffice_filament
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

QUEUE_CONNECTION=redis

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=192.168.0.193
REDIS_PASSWORD=null
REDIS_PORT=6381

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_TOKEN=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=mala-emas-media
CLOUDFLARE_R2_REGION=us-east-1
CLOUDFLARE_R2_ENDPOINT=http://192.168.0.193:9002
CLOUDFLARE_R2_PUBLIC_URL=http://192.168.0.193:9002/mala-emas-media
R2_WIPE_ON_FRESH_SEED=true

VITE_APP_NAME="${APP_NAME}"
VITE_DEV_SERVER_URL=http://hkgoldadmin.test:5173

# Firebase Admin SDK (server → FCM)
FIREBASE_CREDENTIALS=

# Firebase Web client
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# Web Push certificates
WEBPUSH_VAPID_PUBLIC_KEY=
WEBPUSH_VAPID_PRIVATE_KEY=
WEBPUSH_VAPID_SUBJECT=mailto:admin@hkgold.com

NOTIFICATIONS_QUEUE=notifications
